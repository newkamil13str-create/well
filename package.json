{
  "name": "kamilshop",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:wa\" \"npm run dev:tg\"",
    "dev:web": "cd apps/web && next dev",
    "dev:wa": "cd apps/bot-wa && npx ts-node index.ts",
    "dev:tg": "cd apps/bot-tg && npx ts-node index.ts",
    "build": "cd apps/web && next build",
    "start": "cd apps/web && next start"
  },
  "dependencies": {
    "next": "14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "@prisma/client": "^5.14.0",
    "prisma": "^5.14.0",
    "next-auth": "5.0.0-beta.19",
    "bcryptjs": "^2.4.3",
    "@types/bcryptjs": "^2.4.6",
    "@whiskeysockets/baileys": "^6.7.5",
    "telegraf": "^4.16.3",
    "cloudinary": "^2.3.1",
    "slugify": "^1.6.6",
    "react-qr-code": "^2.0.15",
    "react-hot-toast": "^2.4.1",
    "zustand": "^4.5.2",
    "date-fns": "^3.6.0",
    "pino": "^9.2.0",
    "@hapi/boom": "^10.0.1",
    "tailwindcss": "^3.4.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "lucide-react": "^0.395.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.3.0",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "nodemailer": "^6.9.14",
    "@types/nodemailer": "^6.4.15"
  }
}
